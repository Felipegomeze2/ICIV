# Plantilla de credenciales locales del ICIV.
# Copiar a iciv/.env (ignorado por git) y llenar con valores reales.
# NUNCA commitear el .env real ni pegar credenciales en chats o issues.

# EIA International (https://www.eia.gov/opendata/register.php)
EIA_API_KEY=

# The Guardian Open Platform (https://open-platform.theguardian.com/access/)
GUARDIAN_API_KEY=

# ACLED (https://acleddata.com — el API usa email + contraseña de la cuenta via OAuth)
ACLED_EMAIL=
ACLED_PASSWORD=

# US Census international trade (https://api.census.gov/data/key_signup.html)
CENSUS_API_KEY=

# UN Comtrade (https://comtradedeveloper.un.org — primary key de la suscripcion free)
COMTRADE_API_KEY=

# NASA Earthdata (https://urs.earthdata.nasa.gov — Generate Token, dura ~60 dias)
EARTHDATA_TOKEN=
