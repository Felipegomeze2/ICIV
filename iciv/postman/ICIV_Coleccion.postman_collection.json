    {
      "name": "4 — EIA (Energía)",
      "description": "Energy Information Administration API v2. Requiere API key.",
      "item": [
        {
          "name": "EIA — Producción petróleo Venezuela (TBPD)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "https://api.eia.gov/v2/international/data/?api_key={{eia_api_key}}&frequency=annual&data[]=value&facets[productId][]=57&facets[activityId][]=1&facets[countryRegionId][]=VEN&facets[unit][]=TBPD&start=2000&end=2026",
              "host": ["api.eia.gov"],
              "path": ["v2", "international", "data", ""],
              "query": [
                {"key": "api_key", "value": "{{eia_api_key}}"},
                {"key": "frequency", "value": "annual"},
                {"key": "data[]", "value": "value"},
                {"key": "facets[productId][]", "value": "57"},
                {"key": "facets[activityId][]", "value": "1"},
                {"key": "facets[countryRegionId][]", "value": "VEN"},
                {"key": "facets[unit][]", "value": "TBPD"},
                {"key": "start", "value": "2000"},
                {"key": "end", "value": "2026"}
              ]
            },
            "description": "Producción crudo Venezuela en miles de barriles/día. Esperado: ~26 años. Nota: usa facets v2, NO el formato legacy ?seriesId=."
          },
          "response": []
        },
        {
          "name": "EIA — Producción gas natural Venezuela (BCF)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "https://api.eia.gov/v2/international/data/?api_key={{eia_api_key}}&frequency=annual&data[]=value&facets[productId][]=26&facets[activityId][]=1&facets[countryRegionId][]=VEN&facets[unit][]=BCF&start=2000&end=2026",
              "host": ["api.eia.gov"],
              "path": ["v2", "international", "data", ""],
              "query": [
                {"key": "api_key", "value": "{{eia_api_key}}"},
                {"key": "frequency", "value": "annual"},
                {"key": "data[]", "value": "value"},
                {"key": "facets[productId][]", "value": "26"},
                {"key": "facets[activityId][]", "value": "1"},
                {"key": "facets[countryRegionId][]", "value": "VEN"},
                {"key": "facets[unit][]", "value": "BCF"},
                {"key": "start", "value": "2000"},
                {"key": "end", "value": "2026"}
