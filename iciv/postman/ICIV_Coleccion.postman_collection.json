{
  "info": {
    "name": "ICIV Venezuela — Verificación de APIs",
    "description": "Colección completa para probar todas las APIs del proyecto ICIV. Importa también el ambiente 'ICIV_Ambiente.postman_environment.json' para usar las variables.\n\n⛔ REGLA: Solo datos reales. Si la API no responde → la variable queda NaN. No se inventan datos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1 — World Bank WDI",
      "description": "Banco Mundial — World Development Indicators. Sin autenticación.",
      "item": [
        {
          "name": "WDI — PIB crecimiento real (NY.GDP.MKTP.KD.ZG)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "https://api.worldbank.org/v2/country/{{pais_wb}}/indicator/NY.GDP.MKTP.KD.ZG?format=json&per_page=30",
              "host": ["api.worldbank.org"],
              "path": ["v2", "country", "{{pais_wb}}", "indicator", "NY.GDP.MKTP.KD.ZG"],
              "query": [
                {"key": "format", "value": "json"},
                {"key": "per_page", "value": "30"}
              ]
            },
            "description": "Crecimiento real del PIB %. Esperado: ~25 años para Venezuela. Respuesta JSON: array[0]=metadata, array[1]=datos"
          },
          "response": []
        },
        {
          "name": "WDI — Reservas internacionales (FI.RES.TOTL.CD)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "https://api.worldbank.org/v2/country/{{pais_wb}}/indicator/FI.RES.TOTL.CD?format=json&per_page=30",
              "host": ["api.worldbank.org"],
              "path": ["v2", "country", "{{pais_wb}}", "indicator", "FI.RES.TOTL.CD"],
              "query": [
                {"key": "format", "value": "json"},
                {"key": "per_page", "value": "30"}
              ]
            },
            "description": "Reservas totales USD. Venezuela dejó de reportar ~2018. Esperado: ~18 años con datos."
          },
          "response": []
        },
        {
          "name": "WDI — LSCI conectividad marítima (IS.SHP.GCNW.XQ)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "https://api.worldbank.org/v2/country/{{pais_wb}}/indicator/IS.SHP.GCNW.XQ?format=json&per_page=30",
              "host": ["api.worldbank.org"],
              "path": ["v2", "country", "{{pais_wb}}", "indicator", "IS.SHP.GCNW.XQ"],
              "query": [
                {"key": "format", "value": "json"},
                {"key": "per_page", "value": "30"}
              ]
            },
            "description": "Liner Shipping Connectivity Index. Reemplazó al UNCTAD API (404). Esperado: 16 años (2006-2021)."
          },
          "response": []
        },
        {
          "name": "WDI — IED neta USD (BX.KLT.DINV.CD.WD)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "https://api.worldbank.org/v2/country/{{pais_wb}}/indicator/BX.KLT.DINV.CD.WD?format=json&per_page=30",
              "host": ["api.worldbank.org"],
              "path": ["v2", "country", "{{pais_wb}}", "indicator", "BX.KLT.DINV.CD.WD"],
              "query": [
                {"key": "format", "value": "json"},
                {"key": "per_page", "value": "30"}
              ]
            },
            "description": "Inversión Extranjera Directa neta en USD."
          },
          "response": []
        }
      ]
    },
    {
      "name": "2 — World Bank WGI",
      "description": "Governance Indicators — descarga ZIP bulk.",
      "item": [
        {
          "name": "WGI — Verificar ZIP disponible",
          "request": {
            "method": "HEAD",
            "url": {
              "raw": "https://databank.worldbank.org/data/download/WGI_CSV.zip",
              "host": ["databank.worldbank.org"],
              "path": ["data", "download", "WGI_CSV.zip"]
            },
            "description": "Verifica que el ZIP existe. Respuesta 200 = OK. 404 = cambio de URL (verificar mayúsculas CSV vs csv)."
          },
          "response": []
        }
      ]
    },
